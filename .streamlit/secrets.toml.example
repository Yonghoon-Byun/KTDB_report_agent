# .streamlit/secrets.toml — 실제 값으로 채워서 같은 디렉토리에 secrets.toml로 저장
# (gitignore 대상). TOML은 평면 키가 [section] 위쪽에만 위치할 수 있다.
#
# 두 가지 자격증명 프로파일 중 하나를 선택해서 [azure] 블록에 채운다:
#
#   1) 관리자/소유자 (`ktdb`)         — 적재·DDL 가능. 본 저장소 운영자만 사용.
#   2) Read-Only 사용자 (`ktdb_viewer`) — SELECT only. 사내 분배용 (QGIS 플러그인 패턴).
#
# 사용자에게 코드를 분배할 때는 반드시 viewer 자격증명만 포함시킬 것.
# (운영자 비밀번호 분배 금지 — CLAUDE.md 절대 룰 4)

GEMINI_API_KEY    = ""        # 현재 dead code — 빈 값 허용. 향후 LLM 해설 도입 시 채움.
SHEET_URL_SOCIO   = ""        # legacy 시트 (마이그레이션 잔여). 분배본은 비워두면 됨.
SHEET_URL_OBJ_OD  = ""
SHEET_URL_MAIN_OD = ""
SHEET_URL_ACC_OD  = ""

# ─────────────────────────────────────────────
# Azure Postgres (geo-spatial-hub DEV 서버, ktdb 테넌트)
# 분양 절차: docs/테넌트_DB_분양_절차.md
# 사용자 설치: docs/사용자-설치-가이드.md
# ─────────────────────────────────────────────
[azure]
host     = "geo-spatial-hub.postgres.database.azure.com"
port     = 6432              # 일반 쿼리 = PgBouncer (Streamlit이 사용)
port_ddl = 5432              # 적재/스키마 변경용 (운영자만 사용; viewer 프로파일에서는 의미 없음)
database = "ktdb"

# 운영자 프로파일 — 본 저장소 호스트 1대만
# user     = "ktdb"
# password = "..."           # 평문 git 추적 파일 저장 금지

# 사내 분배용 R/O 프로파일 (권장) — 누출되어도 SELECT만 가능
user     = "ktdb_viewer"
password = "<viewer_password_here>"

sslmode  = "require"

# ─────────────────────────────────────────────
# 기존 Supabase (마이그레이션 중 병행 유지, 폐기 시 제거)
# 사내 분배본에는 [supabase] 블록 자체를 빼는 것을 권장.
# ─────────────────────────────────────────────
# [supabase]
# host     = "aws-1-ap-northeast-2.pooler.supabase.com"
# port     = 5432
# database = "postgres"
# user     = "postgres.<project-ref>"
# password = "..."
