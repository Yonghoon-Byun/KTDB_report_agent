# .streamlit/secrets.toml — 실제 값으로 채워서 같은 디렉토리에 secrets.toml로 저장
# (gitignore 대상). TOML은 평면 키가 [section] 위쪽에만 위치할 수 있다.

GEMINI_API_KEY    = "..."
SHEET_URL_SOCIO   = "..."
SHEET_URL_OBJ_OD  = "..."
SHEET_URL_MAIN_OD = "..."
SHEET_URL_ACC_OD  = "..."

# ─────────────────────────────────────────────
# Azure Postgres (geo-spatial-hub DEV 서버, ktdb 테넌트)
# 분양 절차: docs/테넌트_DB_분양_절차.md
# ─────────────────────────────────────────────
[azure]
host     = "geo-spatial-hub.postgres.database.azure.com"
port     = 6432              # 일반 쿼리 = PgBouncer (Streamlit이 사용)
port_ddl = 5432              # 적재/스키마 변경용 (sync_smr.py가 사용)
database = "ktdb"
user     = "ktdb"
password = "..."             # 채팅·문서 등 git 추적 파일에 평문 저장 금지
sslmode  = "require"

# ─────────────────────────────────────────────
# 기존 Supabase (마이그레이션 중 병행 유지, 폐기 시 제거)
# ─────────────────────────────────────────────
[supabase]
host     = "aws-1-ap-northeast-2.pooler.supabase.com"
port     = 5432
database = "postgres"
user     = "postgres.<project-ref>"
password = "..."
